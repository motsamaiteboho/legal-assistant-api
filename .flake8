[flake8]
max-line-length = 127
exclude = .git,__pycache__,.venv,venv,build,dist
# Ignore whitespace noise for now
ignore =
    W291,  # trailing whitespace
    W292,  # no newline at end of file
    W293,  # blank line contains whitespace
# Keep these ON (real bugs)
select = E9,F63,F7,F82,F401,F811,E111,E122,E128,E129,E302,E303,E305,E501,E722,C901
