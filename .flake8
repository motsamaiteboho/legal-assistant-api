[flake8]
max-line-length = 127
exclude = .git,__pycache__,.venv,venv,build,dist

# Ignore style noise for now
ignore =
    E302,
    E303,
    E305,
    E501

# Keep checks that usually break builds / cause bugs
select =
    E9,
    F63,
    F7,
    F82,
    F401,
    F811,
    E111,
    E122,
    E128,
    E129,
    E722
